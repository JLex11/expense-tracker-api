{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "expense-tracker-api",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-19",
	// "compatibility_flags": [
	//   "nodejs_compat"
	// ],
	"vars": {
		"GEMINI_MODEL": "gemini-2.5-flash-lite",
		"GOOGLE_VISION_LOCATION": "global"
	},
	"r2_buckets": [
		{
			"binding": "RECEIPT_IMAGES",
			"bucket_name": "expense-tracker-receipt-images"
		}
	],
	// Optional: enables OCR-aware fuzzy caching between Vision OCR and Gemini.
	// Provision a KV namespace and uncomment before deploy.
	// "kv_namespaces": [
	// 	{
	// 		"binding": "RECEIPT_FUZZY_CACHE",
	// 		"id": "your-kv-namespace-id"
	// 	}
	// ],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "expense-tracker-db",
			"database_id": "ec51241a-65f8-4e16-be1a-1e8aaf823d78",
			"migrations_dir": "drizzle"
		}
	],
	"triggers": {
		"crons": ["0 * * * *"]
	},
	"queues": {
		"producers": [
			{
				"queue": "receipt-scan-jobs",
				"binding": "RECEIPT_SCAN_QUEUE"
			}
		],
		"consumers": [
			{
				"queue": "receipt-scan-jobs",
				"max_batch_size": 1,
				"max_batch_timeout": 5
			}
		]
	}
	// "ai": {
	//   "binding": "AI"
	// },
	// "observability": {
	//   "enabled": true,
	//   "head_sampling_rate": 1
	// }
}
